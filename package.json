{
  "scripts": {
    "backfill:history": "node scripts/backfill-tefas-history.js",
    "dev": "concurrently \"node api-server.js\" \"cd frontend && npm run dev\"",
    "build": "npm run build --prefix frontend",
    "check:csp": "node scripts/check-csp.js",
    "verify:config": "node scripts/verify-environment.js",
    "check": "npm test -- --runInBand && npm run check:csp && npm run build",
    "test": "jest --testPathPatterns='api/__tests__'",
    "test:watch": "jest --watch --testPathPatterns='api/__tests__'"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {}
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@supabase/supabase-js": "^2.89.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "jest": "^30.4.2"
  }
}
